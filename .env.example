# Copy to .env and fill in. Never commit .env.

# Neo4j (required)
GTMDB_NEO4J_URI=
GTMDB_NEO4J_USER=
GTMDB_NEO4J_PASSWORD=
# If Aura ``neo4j+s://`` routing times out from your host (e.g. Railway), set true or switch URI to bolt+s://same-host
# GTMDB_NEO4J_FORCE_DIRECT_BOLT=true
# Optional driver timeouts (seconds)
# GTMDB_NEO4J_CONNECTION_TIMEOUT=60
# GTMDB_NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Tenant UUID for bootstrap / admin token
GTMDB_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# Postgres for agent API keys (asyncpg DSN). Leave unset to use admin key only.
GTMDB_KEY_STORE_URL=

# Admin key — checked locally; grants full access + key management
GTMDB_ADMIN_KEY=

# OpenAI (Analyst agent)
GTMDB_OPENAI_API_KEY=sk-...
GTMDB_PLANNER_MODEL=gpt-4o-mini
GTMDB_PLANNER_MODEL_COMPLEX=gpt-4o

# ClickHouse (OLAP analytics store)
# Local dev (docker-compose):
GTMDB_CLICKHOUSE_HOST=localhost
GTMDB_CLICKHOUSE_PORT=8123
GTMDB_CLICKHOUSE_SECURE=false
GTMDB_CLICKHOUSE_USER=dev
GTMDB_CLICKHOUSE_PASSWORD=devpassword
GTMDB_CLICKHOUSE_DATABASE=gtmdb
# ClickHouse Cloud / production (port 8443, secure=true):
# GTMDB_CLICKHOUSE_HOST=<service>.aws.clickhouse.cloud
# GTMDB_CLICKHOUSE_PORT=8443
# GTMDB_CLICKHOUSE_SECURE=true
# GTMDB_CLICKHOUSE_USER=default
# GTMDB_CLICKHOUSE_PASSWORD=<password>
# GTMDB_CLICKHOUSE_DATABASE=default

# LLM (planner agent — required for /v1/ask and A2A)
GTMDB_OPENAI_API_KEY=
# gpt-4o-mini for simple/single-engine queries, gpt-4o for multi-engine
GTMDB_PLANNER_MODEL=gpt-4o-mini
GTMDB_PLANNER_MODEL_COMPLEX=gpt-4o

# Public base URL for the A2A Agent Card (no trailing slash). In production set to your HTTPS API origin.
# If unset, the card defaults to http://127.0.0.1:$PORT (or GTMDB_SERVER_PORT).
# GTMDB_PUBLIC_URL=https://api.example.com

# Optional server tuning
# GTMDB_SERVER_HOST=0.0.0.0
# GTMDB_SERVER_PORT=8100
# GTMDB_SERVER_EXPLORE_DEFAULT_DEPTH=1
# GTMDB_SERVER_EXPLORE_MAX_DEPTH=3
# GTMDB_SERVER_EXPLORE_NODES_PER_TYPE=10
# Max distinct nodes loaded during explore BFS (hub safety; default 500)
# GTMDB_SERVER_EXPLORE_MAX_DISCOVERED_NODES=500
# Optional: max seconds for Neo4j read transaction used only by GET /v1/entities/{id}/explore (omit = DB default)
# GTMDB_SERVER_EXPLORE_TRANSACTION_TIMEOUT_S=45
