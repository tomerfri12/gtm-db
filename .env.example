# Optional overrides for GtmDB / Neo4j.
#
# By default, ``gtmdb`` uses the shared dev Neo4j Aura connection baked into
# ``src/gtmdb/config.py``. Set variables below (or use a local ``.env``) only
# when you need a different database.
#
# Local Docker: docker compose -f docker-compose.yml up -d
#   GTMDB_NEO4J_URI=bolt://localhost:7687
#   GTMDB_NEO4J_PASSWORD=your_local_password
#
# Your own Aura instance:
#   GTMDB_NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
#
# GTMDB_NEO4J_URI=
# GTMDB_NEO4J_USER=
# GTMDB_NEO4J_PASSWORD=
# GTMDB_DEFAULT_TENANT_ID=
