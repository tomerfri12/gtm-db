# Graph store (Neo4j). Start with: docker compose -f docker-compose.yml up -d
# Copy to repo root `.env` when running CRM2 (CrmdbSettings reads CRMDB_* from cwd).
CRMDB_NEO4J_URI=bolt://localhost:7687
CRMDB_NEO4J_USER=neo4j
CRMDB_NEO4J_PASSWORD=changeme

# Optional: tenant UUID for `python -m crmdb init --seed`
CRMDB_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001
