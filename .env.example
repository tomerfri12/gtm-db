# Graph store (Neo4j). Start with: docker compose -f docker-compose.yml up -d
# Copy to repo root `.env` when running CRM2 (GtmdbSettings reads GTMDB_* from cwd).
GTMDB_NEO4J_URI=bolt://localhost:7687
GTMDB_NEO4J_USER=neo4j
GTMDB_NEO4J_PASSWORD=changeme

# Optional: tenant UUID for `python -m gtmdb init --seed`
GTMDB_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001
