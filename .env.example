# Copy to .env and fill in. Never commit .env.

# Neo4j (required)
GTMDB_NEO4J_URI=
GTMDB_NEO4J_USER=
GTMDB_NEO4J_PASSWORD=
# If Aura ``neo4j+s://`` routing times out from your host (e.g. Railway), set true or switch URI to bolt+s://same-host
# GTMDB_NEO4J_FORCE_DIRECT_BOLT=true
# Optional driver timeouts (seconds)
# GTMDB_NEO4J_CONNECTION_TIMEOUT=60
# GTMDB_NEO4J_CONNECTION_ACQUISITION_TIMEOUT=60

# Tenant UUID for bootstrap / admin token
GTMDB_DEFAULT_TENANT_ID=00000000-0000-4000-8000-000000000001

# Postgres for agent API keys (asyncpg DSN). Leave unset to use admin key only.
GTMDB_KEY_STORE_URL=

# Admin key — checked locally; grants full access + key management
GTMDB_ADMIN_KEY=

# Optional server tuning
# GTMDB_SERVER_HOST=0.0.0.0
# GTMDB_SERVER_PORT=8100
# GTMDB_SERVER_EXPLORE_DEFAULT_DEPTH=1
# GTMDB_SERVER_EXPLORE_MAX_DEPTH=3
# GTMDB_SERVER_EXPLORE_NODES_PER_TYPE=10
